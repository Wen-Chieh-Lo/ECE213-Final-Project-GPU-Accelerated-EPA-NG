# Native build outputs and local binaries
/build/
/build_*/
/bin/
/MLIPPER
/MLIPPER_*
*.o
*.d

# Profiling traces
*.nsys-rep
*.sqlite
*.ncu-rep
*.ncu.log
*.details.txt

# Python cache
__pycache__/
*.py[cod]

